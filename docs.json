              "products/acquiring/subscription",
              "products/acquiring/checkout",
              "products/acquiring/payment-methods"
            ]
          },
          {
            "group": "Payout 代发",
            "pages": [
              "products/payout/overview",
              "products/payout/methods"
            ]
          },
          {
            "group": "结算与资金管理",
            "pages": [
              "products/settlement/merchant-settlement",
              "products/settlement/fx",
              "products/settlement/tax"
            ]
          },
          {
            "group": "风控与合规",
            "pages": [
              "products/risk/security",
              "products/risk/disputes"
            ]
          },
          {
            "group": "增值服务",
            "pages": [
              "products/value-added/data-analytics",
              "products/value-added/merchant-portal",
              "products/value-added/tokenization",
              "products/value-added/auth-capture"
            ]
          }
        ]
      },
      {
