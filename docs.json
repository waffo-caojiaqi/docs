{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Waffo",
  "openapi": "api-reference/openapi.json",
  "colors": {
    "primary": "#2C8CFF",
    "light": "#27CCFF",
    "dark": "#1A6ED8"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://docs.flowjizhang.top"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Products & Services",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index"]
          },
          {
            "group": "Acquiring & Payments",
            "pages": [
              "products/subscription-recurring"
            ]
          }
        ]
      },
      {
        "tab": "Integration Guide",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets",
              "essentials/custom-components"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@waffo.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://portal.waffo.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/waffo",
      "github": "https://github.com/waffo-org",
      "linkedin": "https://linkedin.com/company/waffo"
    }
  },
  "background": {
    "decoration": "gradient"
  }
}
