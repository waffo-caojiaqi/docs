{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Waffo",
  "openapi": "api-reference/openapi.json",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://docs.flowjizhang.top"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Order Management",
            "pages": [
              { "openapi": "POST /api/v1/order/create" },
              { "openapi": "POST /api/v1/order/inquiry" },
              { "openapi": "POST /api/v1/order/cancel" },
              { "openapi": "POST /api/v1/order/refund" },
              { "openapi": "POST /api/v1/refund/inquiry" }
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              { "openapi": "POST /api/v1/merchantconfig/inquiry" },
              { "openapi": "POST /api/v1/paymethodconfig/inquiry" }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@waffo.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://portal.waffo.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/waffo"
    }
  },
  "background": {
    "decoration": "gradient"
  }
}
